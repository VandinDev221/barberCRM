# Evolution API - Barber CRM
# Copie para .env: copy .env.example .env
# Depois defina AUTHENTICATION_API_KEY (essa chave você usa no Barber CRM como WHATSAPP_API_KEY)

# Chave de acesso à API (obrigatório) - use no header "apikey" e na Vercel como WHATSAPP_API_KEY
AUTHENTICATION_API_KEY=sua-chave-secreta-aqui

# URL onde a API está acessível (local: http://localhost:8080; produção: https://seu-dominio.com)
SERVER_URL=http://localhost:8080

# PostgreSQL (já usados pelo docker-compose)
POSTGRES_DATABASE=evolution
POSTGRES_USERNAME=evolution
POSTGRES_PASSWORD=evolution_secret
