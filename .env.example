# ===========================================
# BARBER CRM - Variáveis de Ambiente
# ===========================================
# Copie para .env e preencha os valores

# --- Backend ---
NODE_ENV=development
PORT=3001
API_PREFIX=api

# Banco de Dados
DATABASE_URL="postgresql://barber:barber_secret@localhost:5432/barber_crm?schema=public"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_REFRESH_EXPIRES_IN=30d

# Redis (opcional - cache e filas)
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false

# App
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# WhatsApp (opcional - lembretes e campanhas)
# Use API como Twilio, Evolution API ou similar
WHATSAPP_ENABLED=false
WHATSAPP_API_URL=
WHATSAPP_API_KEY=
WHATSAPP_PHONE_ID=

# Rate Limit
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Log
LOG_LEVEL=debug

# --- Stripe (backend Render) ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...
# Webhook endpoint: https://seu-backend.onrender.com/api/billing/webhook
# Eventos: checkout.session.completed, customer.subscription.created,
# customer.subscription.updated, customer.subscription.deleted, invoice.payment_failed

# --- Frontend (build) ---
# Local: use o backend local. Produção (Vercel): use a URL pública do backend no Render.
NEXT_PUBLIC_API_URL=http://localhost:3001
# Google Sign-In (mesmo Client ID do backend GOOGLE_CLIENT_ID)
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com
# Exemplo produção: NEXT_PUBLIC_API_URL=https://barbercrm.onrender.com
# Meta Pixel (Facebook/Instagram Ads) — obrigatório em produção na Vercel
NEXT_PUBLIC_META_PIXEL_ID=
# Teste no Gerenciador de Eventos (Conversions API / Graph API)
# META_CAPI_ACCESS_TOKEN=token_gerado_em_events_manager_conversions_api
# META_PIXEL_ID=opcional_se_diferente_do_publico
# META_PIXEL_TEST_EVENT_CODE=TEST71427
# NEXT_PUBLIC_APP_URL=https://barber-painel.vercel.app

# --- Vercel: Evolution API (plataforma — cada barbeiro conecta o QR em Configurações) ---
# EVOLUTION_API_URL=https://sua-evolution.onrender.com
# EVOLUTION_API_KEY=sua-apikey-global
# (aliases aceitos: WHATSAPP_API_URL e WHATSAPP_API_KEY)
