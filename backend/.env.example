# ===========================================
# BARBER CRM - Backend - Variáveis de Ambiente
# ===========================================
# Copie para .env: copy .env.example .env

NODE_ENV=development
PORT=3001
API_PREFIX=api

# Banco de Dados (obrigatório)
DATABASE_URL="postgresql://barber:barber_secret@localhost:5432/barber_crm?schema=public"

# JWT (obrigatório)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_REFRESH_EXPIRES_IN=30d

# Redis (opcional)
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=false

# Rate Limit
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Fuso do barbeiro para o link público de agendamento (horário local = UTC + este valor).
# Brasil (UTC-3): use 3. Outros: ajuste conforme seu fuso (ex.: UTC-2 = 2).
BARBER_TZ_OFFSET_HOURS=3

# Evolution API (plataforma — configure na Vercel OU no Render do backend)
EVOLUTION_API_URL=https://sua-evolution.onrender.com
EVOLUTION_API_KEY=sua-apikey-global-da-evolution

# Se Evolution estiver só na Vercel, defina APP_URL para o backend enviar via proxy:
APP_URL=https://seu-frontend.vercel.app
# WHATSAPP_PROXY_SECRET=opcional-mesma-chave-ou-deixe-usar-EVOLUTION_API_KEY

# Mensagem de aniversário: envio automático todo dia às 09:00 (fuso do barbeiro).
# BIRTHDAY_WHATSAPP_ENABLED=true

# Stripe (obrigatório em produção)
STRIPE_SECRET_KEY=sk_test_sua_chave_secreta
STRIPE_WEBHOOK_SECRET=whsec_seu_webhook_secret
# Webhook: POST https://seu-backend.onrender.com/api/billing/webhook
# Eventos: checkout.session.completed, customer.subscription.created,
# customer.subscription.updated, customer.subscription.deleted, invoice.payment_failed
STRIPE_PRICE_ID=price_id_do_plano_mensal
STRIPE_TRIAL_DAYS=7

# URL pública do frontend (checkout success/cancel e portal)
APP_URL=https://seu-frontend.vercel.app

# Apenas desenvolvimento local — ignora bloqueio de assinatura
# BYPASS_SUBSCRIPTION=true

# Google OAuth (login com Google)
GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com

LOG_LEVEL=debug
